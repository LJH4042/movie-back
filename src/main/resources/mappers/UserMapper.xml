<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.back.mapper.UserMapper">
    <!--회원가입-->
    <insert id="register">
        INSERT INTO USER_TBL ( USER_NO, USER_ID, USER_PW, USER_EMAIL, REG_DATE )
        VALUES ( USER_SEQ.NEXTVAL, #{USER_ID}, #{USER_PW}, #{USER_EMAIL}, SYSDATE )
    </insert>

    <!--로그인 회원 검증-->
    <select id="findByUserId" resultType="com.example.back.entity.UserEntity">
        SELECT * FROM USER_TBL WHERE USER_ID = #{USER_ID}
    </select>
</mapper>